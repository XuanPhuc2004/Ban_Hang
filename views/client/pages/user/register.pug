extends ../../layouts/default.pug

block main
  .container.my-4
    .row.justify-content-center
      .col-md-6
        .card.shadow-sm
          h1(class="text-center") Đăng ký tài khoản
          .card-body
            form(action="/user/register" method="POST")

              .mb-3
                label.form-label Họ tên
                input.form-control(
                  type="text"
                  name="fullName"
                  id="fullName"
                  placeholder="Nhập họ tên"
                  required
                )

              .mb-3
                label.form-label Email
                input.form-control(
                  type="email"
                  name="email"
                  id="email"
                  placeholder="Nhập email"
                  required
                )

              .mb-3
                label.form-label Mật khẩu
                input.form-control(
                  type="password"
                  name="password"
                  id="password"
                  placeholder="Nhập mật khẩu"
                  required
                )

              .d-grid
                button.btn.btn-primary(type="submit")
                  | Đăng ký

            hr

            .text-center
              span Bạn đã có tài khoản? 
              a(href="/user/login") Đăng nhập