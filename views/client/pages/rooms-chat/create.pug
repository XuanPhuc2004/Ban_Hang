extends ../../layouts/default.pug
include ../../mixins/box-head.pug

block main
  .container.my-4
    .row
      .col-12
        +box-head("Tạo phòng chat")

    .row.justify-content-center
      .col-md-6

        .card.shadow-sm
          .card-body

            form(
              action="/rooms-chat/create"
              method="POST"
              enctype="multipart/form-data"
            )

              // ===== ROOM NAME =====
              .mb-3
                label.form-label.fw-bold Tên phòng
                input.form-control(
                  type="text"
                  name="title"
                  placeholder="Nhập tên phòng..."
                  required
                )

              // ===== AVATAR =====
              div.form-group(upload-image)
                label(for="avatar") Avatar

                input.form-control-file(
                  type="file"
                  id="avatar"
                  name="avatar"
                  accept="image/*"
                  upload-image-input
                )

                img(
                  src=""
                  upload-image-preview
                  class="image-preview mt-2"
                  width="150"
                )


             

              // ===== MEMBERS (optional) =====
              .mb-3
                label.form-label.fw-bold Thêm thành viên
                each friend in friendList
                  div(class="form-check")
                    input(
                      type="checkbox"
                      class="form-check-input"
                      value=friend.user_id
                      id=`user-${friend.user_id}`
                      name="usersId"
                      ) 
                    label(class="form-check-label"
                    for=`user-${friend.user_id}`) #{friend.infoFriend.fullName}

              // ===== SUBMIT =====
              .mt-4.text-end
                button.btn.btn-success(type="submit")
                  | Tạo phòng

                a.btn.btn-secondary.ms-2(
                  href="/rooms-chat"
                ) Hủy
              
    script(src="/admin/js/script.js")