extends ../../layouts/default.pug
include ../../mixins/box-head.pug 

block main
  .container.my-3

    .row
      .col-12
        +box-head("Chat trực tiếp")
        .chat(my-id=user.id )
          .inner-body 
            each chat in chats 
              div(class=(chat.user_id == user.id ? "inner-outgoing" : "inner-incoming "))
                if(chat.user_id != user.id)
                  if(chat.infoUser)
                    .inner-name #{chat.infoUser.fullName}
                  else
                    .inner-name Unknown
                if(chat.content)
                  .inner-content #{chat.content}
            
            div(class="inner-list-typing")
          .inner-foot 
            form(action=""
              class="inner-form"
            ) 
              input(
                type="text"
                placeholder="Nhập nội dung "
                name="content"
              )
              span(class="button-icon btn btn-light  icons") 
                i.fa-regular.fa-face-grin-wink
              button
                i.fa-solid.fa-paper-plane
    div(class="tooltip" role="tooltip")
      emoji-picker(class="light")