extends ../../layouts/default.pug 

block main 
  if(role.permissions.includes("roles_view"))
    h1.mb-4 Nhóm quyền

    .card.mb-3 
      .card-header Danh sách 
      .card-body 
        .row.mb-3
          .col-8
          .col-4.text-end
            if(role.permissions.includes("roles_create"))
              a.btn.btn-outline-success(
                href=`${prefixAdmin}/roles/create`
              ) + Thêm mới 

        table.table.table-hover.table-sm
          thead
            tr
              th STT
              th Nhóm quyền
              th Mô tả ngắn
              th Hành động
          tbody
            if records && records.length > 0
              each item, index in records
                tr
                  td #{index + 1}
                  td #{item.title}
                  td !{item.description}
                  td
                    a.btn.btn-secondary.btn-sm.me-1(
                      href=`${prefixAdmin}/roles/detail/${item._id}`
                    ) Chi tiết
                    if(role.permissions.includes("roles_edit"))
                      a.btn.btn-warning.btn-sm.me-1(
                        href=`${prefixAdmin}/roles/edit/${item._id}`
                      ) Sửa
                    if(role.permissions.includes("roles_edit"))
                      button.btn.btn-danger.btn-sm.btn-delete-role(
                        type="button"
                        data-id=item._id
                      ) Xóa
                    
            else
              tr
                td.text-center(colspan="4") Chưa có nhóm quyền nào được tạo!
  form(
  method="POST"
  id="form-delete-role"
)