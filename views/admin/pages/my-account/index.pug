extends ../../layouts/default.pug

block main
  h1.mb-4 Thông tin cá nhân
  if(user.avatar)
    img(src=user.avatar width="150px" class="mb-3", alt="avatar")
  else 
    img(src="/admin/images/avatar.png" width="150px" class="mb-3", alt="no avatar")
  
  if(user.fullName)
    p Họ tên: <b>#{user.fullName}</b>

  if(user.email)
    p Email: <b>#{user.email}</b>

  if(user.phone)
    p Số điện thoại: <b>#{user.phone}</b>
  
  p 
    span Trạng thái: 
    span 
      <b>#{user.status === 'active' ? 'Hoạt động' : 'Ngừng hoạt động'} </b>
  if(role.title)
    p Phân quyền: <b>#{role.title}</b>
  
  a(
    href=`${prefixAdmin}/my-account/edit`
    class="btn btn-primary"
    ) Chỉnh sửa thông tin