extends ../../layouts/default.pug

block main

  h1(class="mb-4") Danh mục sản phẩm
  // ===== TOOLBAR =====
  div(class="card mb-3")
    div(class="card-header") Danh sách danh mục
    div(class="card-body")
      div(class="row align-items-center")
        div(class="col-md-6")
        div(class="col-md-6 text-end")
          a(
            href=`${prefixAdmin}/products-category/create`
            class="btn btn-success"
          ) + Thêm mới

  // ===== TABLE =====
  div(class="card")
    div(class="card-body p-0")
      table(
        class="table table-bordered table-hover mb-0"
      )
        thead(class="table-dark")
          tr
            th STT
            th Tên danh mục
            th Danh mục cha
            th Hình ảnh
            th Vị trí
            th Trạng thái
            th Hành động
        tbody
          each item, index in records
            tr
              td #{index + 1}
              td #{item.title}
              td
                if item.parent
                  #{item.parent.title}
                else
                  span(class="text-muted") Không có
              td
                if item.thumbnail
                  img(
                    src=item.thumbnail
                    width="60"
                    alt=item.title
                  )
                else
                  span(class="text-muted") --
              td #{item.position}
              td
                if(item.status == "active")
                  span(
                    data-status=item.status
                    data-id=item.id
                    button-change-status
                  class="badge bg-success") Hoạt động
                else
                  span(
                    data-status=item.status
                    data-id=item.id
                    button-change-status
                  class="badge bg-danger") Ngừng hoạt động
              td

                a(
                  href=`${prefixAdmin}/products-category/detail/${item._id}`
                  class="btn btn-sm btn-secondary me-1"
                ) Chi tiết

                a(
                  href=`${prefixAdmin}/products-category/edit/${item._id}`
                  class="btn btn-sm btn-warning me-1"
                ) Sửa

                button(
                  type="button"
                  class="btn btn-sm btn-danger"
                  data-id=item._id
                  button-delete
                ) Xóa


  script(src="/admin/js/category.js")
