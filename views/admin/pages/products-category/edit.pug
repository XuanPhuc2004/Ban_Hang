extends ../../layouts/default.pug
include ../../mixins/select-tree.pug

block main
  if(role.permissions.includes("products-category_edit"))
    h1(class="mb-4") Chỉnh sửa danh mục sản phẩm

    div(class="card shadow-sm")
      div(class="card-body")
        form(
          action=`${prefixAdmin}/products-category/edit/${data.id}?_method=PATCH`
          method="POST"
          enctype="multipart/form-data"
        )

          // ===== TITLE =====
          div(class="mb-3")
            label(for="title" class="form-label fw-bold") Tên danh mục
            input(
              type="text"
              id="title"
              name="title"
              class="form-control"
              required
              value=data.title
            )

          // ===== PARENT =====
          div(class="mb-3")
            label(for="parent_id" class="form-label fw-bold") Danh mục cha

            select(
              id="parent_id"
              name="parent_id"
              class="form-control"
            )
              option(value="") -- Không có --
              if(records)
                +select-tree(records, 1, data.parent_id)

          // ===== DESCRIPTION =====
          div(class="mb-3")
            label(for="desc" class="form-label fw-bold") Mô tả
            textarea(
              id="desc"
              name="description"
              class="form-control textarea-mce"
              rows="5"
            ) #{data.description}

          // ===== THUMBNAIL =====
          div(class="mb-3" upload-image)
            label(for="thumbnail" class="form-label fw-bold") Ảnh đại diện

            input(
              type="file"
              id="thumbnail"
              name="thumbnail"
              class="form-control-file"
              accept="image/*"
              upload-image-input
            )

            if(data.thumbnail)
              img(
                src=data.thumbnail
                upload-image-preview
                class="image-preview mt-3"
              )
            else
              img(
                src=""
                upload-image-preview
                class="image-preview mt-3"
              )

          // ===== POSITION =====
          div(class="mb-3")
            label(for="position" class="form-label fw-bold") Vị trí
            input(
              type="number"
              id="position"
              name="position"
              class="form-control"
              min="1"
              value=data.position
            )

          // ===== STATUS =====
          div(class="mb-3")
            label(class="form-label fw-bold d-block") Trạng thái

            div(class="form-check form-check-inline")
              input(
                type="radio"
                id="statusActive"
                name="status"
                value="active"
                class="form-check-input"
                checked=data.status === 'active'
              )
              label(for="statusActive" class="form-check-label") Hoạt động

            div(class="form-check form-check-inline")
              input(
                type="radio"
                id="statusInactive"
                name="status"
                value="inactive"
                class="form-check-input"
                checked=data.status === 'inactive'
              )
              label(for="statusInactive" class="form-check-label") Dừng hoạt động

          // ===== SUBMIT =====
          div(class="mt-4")
            button(type="submit" class="btn btn-primary") Cập nhật

            a(
              href=`${prefixAdmin}/products-category`
              class="btn btn-outline-secondary ms-2"
            ) Quay lại

  script(src="/admin/js/product.js")
