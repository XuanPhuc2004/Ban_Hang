extends ../../layouts/default.pug 

block main 
  if(role.permissions.includes("accounts_view"))
    h1.mb-4 Danh sách tài khoản 

    .card.mb-3 
      .card-header Danh sách 
      .card-body 
        .row.mb-3
          .col-8
          .col-4.text-end
            if(role.permissions.includes("accounts_create"))
              a(
                href=`${prefixAdmin}/accounts/create`
                class="btn btn-outline-success"
              ) + Thêm mới

        table.table.table-hover.table-sm
          thead
            tr
              th STT
              th Avatar
              th Họ tên
              th Nhóm quyền
              th Email
              th Trạng thái
              th Hành động
          tbody
            if records.length > 0
              each item, index in records
                tr
                  td #{index + 1}
                  td 
                    img(
                      src=item.avatar  
                      alt="ảnh đại diện"
                      width="100px"
                      height="auto"
                      )
                  td #{item.fullName}
                  td #{item.role.title}
                  td #{item.email}
                  td
                    if item.status === "active"
                      span.badge.bg-success Hoạt động
                    else
                      span.badge.bg-secondary Ngừng

                  td
                    a.btn.btn-sm.btn-info(
                      href=`${prefixAdmin}/accounts/detail/${item._id}`
                    ) Chi tiết
                    if(role.permissions.includes("accounts_edit"))
                      a.btn.btn-sm.btn-warning.ms-1(
                        href=`${prefixAdmin}/accounts/edit/${item._id}`
                      ) Sửa
                    if(role.permissions.includes("accounts_delete"))
                      button.btn.btn-sm.btn-danger.btn-delete-account(
                        type="button"
                        data-id=item._id
                      ) Xóa

            else
              tr
                td.text-center(colspan="7") Chưa có tài khoản nào!

      form(method="POST" id="form-delete-account")

  script(src="/admin/js/acounts.js") 
