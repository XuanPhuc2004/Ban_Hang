extends ../../layouts/default.pug 

block main 
  if(role.permissions.includes("accounts_create"))
    h1.mb-4 Thêm mới tài khoản

    form(
      action=`${prefixAdmin}/accounts/create`
      method="POST"
      enctype="multipart/form-data"
    )
      .row
        .col-md-6
          .mb-3
            label.form-label Họ và tên
            input.form-control(
              type="text"
              name="fullName"
              placeholder="Nhập họ và tên"
              required
            )

        .col-md-6
          .mb-3
            label.form-label Email
            input.form-control(
              type="email"
              id="email"
              name="email"
              placeholder="Nhập email"
              required
            )

      .row
        .col-md-6
          .mb-3
            label.form-label Mật khẩu
            input.form-control(
              type="password"
              name="password"
              placeholder="Nhập mật khẩu"
              required
            )

        .col-md-6
          .mb-3
            label.form-label Số điện thoại
            input.form-control(
              type="text"
              name="phone"
              placeholder="Nhập số điện thoại"
              id="phone"
            )

      .row
        .col-md-6
          .mb-3
            label.form-label Phân quyền
            select.form-select(name="role_id" )
              option(value="") -- Chọn nhóm quyền --
              each item in roles  
                option(value=item.id) #{item.title}
              

        .col-md-6
          .mb-3
            label.form-label Trạng thái
            select.form-select(name="status")
              option(value="active") Hoạt động
              option(value="inactive") Ngừng hoạt động

      .mb-3
        label.form-label Ảnh đại diện
        input.form-control(
          type="file"
          name="avatar"
          accept="image/*"
        )

      .mt-4
        button.btn.btn-primary(type="submit") Tạo tài khoản
        a.btn.btn-secondary.ms-2(href=`${prefixAdmin}/accounts`) Quay lại
