extends ../../layouts/default.pug

block main
  if(role.permissions.includes("accounts_edit"))
    h1.mb-4 Chỉnh sửa tài khoản

    form(
      action=`${prefixAdmin}/accounts/edit/${data._id}?_method=PATCH`
      method="POST"
      enctype="multipart/form-data"
    )
      .card
        .card-body
          .mb-3
            label.form-label Họ tên
            input.form-control(
              type="text"
              name="fullName"
              value=data.fullName
              required
            )
          .mb-3
            div(class="form-group"
            upload-image
          )
            label(for="thumbnail") Avatar
            input.form-control-file(
              type="file"
              id="avatar"
              name="avatar"
              accept="image/*"
              upload-image-input
            )
            img(
              src=""
              upload-image-preview,
              class="image-preview"
            )


          .mb-3
            label.form-label Email
            input.form-control(
              type="email"
              name="email"
              value=data.email
              readonly
            )

          .mb-3
            label.form-label Mật khẩu mới
            input.form-control(
              type="password"
              name="password"
              placeholder="Để trống nếu không đổi mật khẩu"
            )

          .mb-3
            label.form-label Nhóm quyền
            select.form-select(name="role_id" required)
              option(value="") -- Chọn nhóm quyền --
              each role in roles
                option(
                  value=role._id
                  selected=(String(role._id) === String(data.role_id))
                )= role.title

          .mb-3
            label.form-label Trạng thái
            select.form-select(name="status")
              option(value="active" selected=data.status === "active") Hoạt động
              option(value="inactive" selected=data.status === "inactive") Ngừng hoạt động

        .card-footer.text-end
          a.btn.btn-secondary.me-2(
            href=`${prefixAdmin}/accounts`
          ) Quay lại

          button.btn.btn-primary(type="submit") Cập nhật
