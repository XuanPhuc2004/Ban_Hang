header.header-admin
  .container-fluid
    .d-flex.justify-content-between.align-items-center.py-2

      // Logo
      .inner-logo
        a.logo(href=`${prefixAdmin}/dashboard`)
          i.bi.bi-speedometer2.me-2
          | Admin Panel

      // Right side
      .d-flex.align-items-center.gap-2
        .user-info
          a.btn.btn-light.btn-sm.user-btn(
            href=`${prefixAdmin}/my-account`
          )
            i.bi.bi-person-circle.me-1
            | #{user.fullName}

        a.btn.btn-danger.btn-sm(
          href=`${prefixAdmin}/auth/logout`
        )
          i.bi.bi-box-arrow-right.me-1
          | Đăng xuất