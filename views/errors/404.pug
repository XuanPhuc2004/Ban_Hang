extends ../layouts/default.pug

block main
  .d-flex.justify-content-center.align-items-center(style="min-height: 70vh")
    .text-center
      h1.display-1.text-danger 404
      h2.mb-3 Không tìm thấy trang
      p.text-muted.mb-4
        | Trang bạn đang tìm không tồn tại hoặc đã bị xoá.

      a(
        href="/"
        class="btn btn-primary me-2"
      ) Về trang chủ

      a(
        href="javascript:history.back()"
        class="btn btn-outline-secondary"
      ) Quay lại
